# ── Gemini AI ──────────────────────────────────────────────────────────
# Required for AI diagnostic and mechanic-input parsing features.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ── PostgreSQL (Railway injects DATABASE_URL automatically) ────────────
# For local development, use your own Postgres connection string.
DATABASE_URL="postgresql://user:password@localhost:5432/taller_manager"

# ── App URL ─────────────────────────────────────────────────────────────
APP_URL="MY_APP_URL"

# ── Server ───────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
